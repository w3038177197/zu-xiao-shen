AI_PROXY_PORT=8787
AI_PROXY_ALLOWED_ORIGIN=http://localhost:5173
AI_PROXY_PROVIDER=DeepSeek

# 平台统一模型 Key。访问用户不会看到也不需要填写 API Key。
# 只在服务端 .env 中配置，用于 /api/ai/chat 后端代理调用。
AI_PROXY_API_KEY=sk-your-server-side-key

# 国内常用服务商专属 Key，按你实际使用的平台填写一个即可。
# 例如默认使用 DeepSeek，就填写 DEEPSEEK_API_KEY。
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
BAICHUAN_API_KEY=
HUNYUAN_API_KEY=
ARK_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=

# 可选：服务端强制覆盖上游地址或模型。一般保持空，让前端服务商预设自动匹配。
AI_PROXY_BASE_URL=
AI_PROXY_MODEL=deepseek-v4-flash

# 可选：允许自定义网关把前端填写的 Base URL 传给代理。
# 当前前端已删除“用户自带模型”入口，建议保持 false。
AI_PROXY_ALLOW_CUSTOM_UPSTREAM=false

# 可选：允许前端覆盖预设服务商的 Base URL。建议保持 false，预设服务商使用后端白名单地址。
AI_PROXY_ALLOW_CLIENT_BASE_URL=false
